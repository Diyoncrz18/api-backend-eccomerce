# ============================================================
#  BACKEND - Environment Variables
#  Salin file ini menjadi .env dan isi dengan nilai yang benar
# ============================================================

# ─── MySQL Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=backend_final
DB_USERNAME=root
DB_PASSWORD=GANTI_DENGAN_PASSWORD_MYSQL_ANDA

# ─── Server ────────────────────────────────────────────────────
SERVER_PORT=8081

# ─── JWT Secret (minimal 32 karakter hex) ──────────────────────
JWT_SECRET=36763979244226452948404D635166546A576D5A7134743777217A25432A462D
JWT_ACCESS_EXPIRATION_MS=7200000
JWT_REFRESH_EXPIRATION_MS=10800000

# ─── Cookie ────────────────────────────────────────────────────
USE_SECURE_COOKIE=false

# ─── CORS (URL frontend) ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── RAG Chatbot - Gemini API ──────────────────────────────────
# Dapatkan API key GRATIS di: https://aistudio.google.com/app/apikey
# Kalau kosong, chatbot akan fallback ke mode rekomendasi tanpa LLM.
GEMINI_API_KEY=
# Opsional override (default sudah ok untuk kebanyakan kasus):
# Daily free-tier quota:
#   gemini-2.5-flash-lite (default) ~1000 RPD — ideal development & production ringan
#   gemini-2.5-flash                ~20-250 RPD — kualitas premium, quota terbatas
#   gemini-2.5-pro                  ~100 RPD    — kualitas tertinggi
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_TEMPERATURE=0.7
# GEMINI_MAX_OUTPUT_TOKENS=500
# Gemini 2.5 "thinking" budget: 0 = off (best for chat). -1 = auto. >0 = limit.
# GEMINI_THINKING_BUDGET=0
# Retry transient errors (503/429/5xx). Free tier hits 429 cepat — set hingga 3-5.
# GEMINI_RETRY_ATTEMPTS=3
# GEMINI_RETRY_BACKOFF_MS=500
# RAG_TOP_K=6
# RAG_HISTORY_MAX=6

# ─── RAG Phase 2 - Semantic Embeddings (Opsional) ──────────────────────────────
# Model embedding Gemini (default: gemini-embedding-001, Matryoshka 3072 dims).
# EMBEDDING_MODEL=gemini-embedding-001
# Output dims via Matryoshka truncation (1-3072). 768 = balance speed/quality.
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_BATCH_SIZE=25
# Matikan kalau mau startup cepat & retrieval keyword-only:
# EMBEDDING_ENABLED=false
# EMBEDDING_BOOTSTRAP=false
# Tuning bobot hybrid (total semantic+keyword sebaiknya = 1.0):
# RAG_SEMANTIC_WEIGHT=0.65
# RAG_KEYWORD_WEIGHT=0.35
